<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="ru.voboost.voiceassistant">

    <!-- ✅ Микрофон (обязательно) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- ✅ Чтение контактов (для звонков по имени) -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- ✅ Доступ к контактам BluetoothPhone -->
    <!-- Объявляем permission явно как normal, чтобы система приняла наше объявление -->
    <permission
        android:name="com.qinggan.bluetoothphone.PROVIDER"
        android:protectionLevel="normal" />
    <uses-permission android:name="com.qinggan.bluetoothphone.PROVIDER" />
    <permission
        android:name="com.qinggan.permission.WRITE_CANBUS"
        android:protectionLevel="normal" />
    <uses-permission android:name="com.qinggan.permission.WRITE_CANBUS" />
    <!-- ✅ Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- ✅ Доступ к внешнему хранилищу (для системных приложений) -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- ✅ Поверх других окон (для overlay) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- ✅ Доступ к интернету -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- ✅ Автозапуск -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- ✅ Для автомобильных систем -->
    <uses-permission android:name="android.car.permission.CAR_POWER" />
    <uses-permission android:name="android.car.permission.CAR_VENDOR_EXTENSION" />
    <uses-permission android:name="android.car.permission.CAR_CONTROL_AUDIO_VOLUME" />
    <!-- ✅ Не спать -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <queries>
        <!-- Пакет приложения, к которому вы подключаетесь через AIDL -->
        <package android:name="com.qinggan.canbus.service" />
        <!-- Также можно добавить поиск по action, если пакет вдруг изменится -->
        <intent>
            <action android:name="com.qinggan.canbus.CanBusService" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_voice"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.VoboostVoice"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- ✅ Невидимая Activity для foreground context при автозапуске -->
        <activity
            android:name=".BootActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:exported="true"
            android:stateNotNeeded="true" />

        <!-- ✅ Главный сервис -->
        <service
            android:name=".VoboostVoiceService"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:foregroundServiceType="microphone"
            android:stopWithTask="false">
            <intent-filter>
                <action android:name="ru.voboost.voiceassistant.START" />
                <!-- Добавьте стандартный экшен для голосовых сервисов -->
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
        </service>

        <!-- ✅ Receiver для команд -->
        <receiver
            android:name=".VoiceCommandReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="ru.voboost.voiceassistant.ACTIVATE" />
                <action android:name="ru.voboost.voiceassistant.CANCEL" />
            </intent-filter>
        </receiver>

        <!-- ✅ Автозапуск -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.REBOOT" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
